# ==============================================
# HR System Docker Compose Environment
# ==============================================
# This file is for Docker Compose deployment
# Copy to .env in the same directory as docker-compose.yml

# ==============================================
# Database Configuration
# ==============================================

# PostgreSQL (recommended for production)
DB_URL=jdbc:postgresql://postgres:5432/hrdb
DB_USERNAME=hruser
DB_PASSWORD=CHANGE_THIS_SECURE_PASSWORD

# H2 File Database (simple, no PostgreSQL needed)
# DB_URL=jdbc:h2:file:/app/data/hrdb
# DB_USERNAME=sa
# DB_PASSWORD=

# ==============================================
# Security Configuration
# ==============================================

# JWT Secret (MUST CHANGE in production!)
# Generate with: openssl rand -base64 64
APP_JWT_SECRET=CHANGE_THIS_TO_VERY_LONG_RANDOM_STRING_MINIMUM_32_CHARACTERS

# Admin credentials (change after first login!)
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD

# ==============================================
# CORS Configuration
# ==============================================

# Add your Vercel frontend URL here
# Example: CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# ==============================================
# Telegram Bot (Optional)
# ==============================================

# Get from @BotFather. Leave empty to disable
HR_BOT_TOKEN=
HR_BOT_USERNAME=

# Production example:
# HR_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
# HR_BOT_USERNAME=my_hr_bot

# ==============================================
# Production Deployment Steps:
# ==============================================
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and change all CHANGE_THIS values
# 3. Update CORS_ALLOWED_ORIGINS with your Vercel URL
# 4. Run: docker compose up -d
# 5. Backend will be available at: http://your-server-ip:8080
