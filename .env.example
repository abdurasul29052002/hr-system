# ==============================================
# HR System — Docker Compose deployment env
# ==============================================
# Copy to `.env` next to docker-compose.yml on the server, then fill in every value.
# docker-compose.yml sets SPRING_PROFILES_ACTIVE=prod and DB_HOST=db / DB_PORT=5432
# (the `db` service), so you do NOT set those here. Backend serves on port 9090.

# ---------- PostgreSQL (shared by backend + postgres service) ----------
DB_NAME=hrdb
DB_USER=hruser
DB_PASSWORD=CHANGE_THIS_SECURE_PASSWORD

# ---------- Security ----------
# Generate: openssl rand -base64 64   (minimum 32 characters)
APP_JWT_SECRET=CHANGE_THIS_TO_VERY_LONG_RANDOM_STRING_MINIMUM_32_CHARACTERS
# Seed admin, created on first startup — change the password after first login
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD

# ---------- S3 file storage (attachments & comment images) ----------
# S3 is the ONLY file backend — uploads fail without it. All S3_* are required (no defaults).
# For AWS S3 leave S3_ENDPOINT empty; for DigitalOcean Spaces / MinIO set the endpoint URL.
S3_ENABLED=true
S3_REGION=us-east-1
S3_BUCKET_NAME=your-bucket-name
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_ENDPOINT=

# ---------- CORS ----------
# Your Vercel frontend URL(s), comma-separated
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# ---------- Telegram bot (optional; leave empty to disable) ----------
HR_BOT_TOKEN=
HR_BOT_USERNAME=
