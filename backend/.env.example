# ==============================================
# HR System Backend Environment Configuration
# ==============================================

# ==============================================
# Database Configuration
# ==============================================
# Development: H2 file database (default, no setup needed)
# Production: PostgreSQL recommended

# PostgreSQL (Production)
DB_URL=jdbc:postgresql://localhost:5432/hrdb
DB_USERNAME=hruser
DB_PASSWORD=your_secure_database_password_here

# H2 (Development - default)
# DB_URL=jdbc:h2:file:./data/hrdb
# DB_USERNAME=sa
# DB_PASSWORD=

# ==============================================
# Security Configuration
# ==============================================

# JWT Secret Key
# IMPORTANT: Change this to a strong random string in production!
# Must be at least 32 characters for HS256
# Generate: openssl rand -base64 64
APP_JWT_SECRET=change-this-to-very-long-random-secret-key-minimum-32-characters-for-production

# Admin Account (created on first startup)
# IMPORTANT: Change these credentials immediately after first login!
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=admin123

# ==============================================
# CORS Configuration
# ==============================================

# Allowed origins (comma-separated)
# Add your Vercel frontend URL here
# Local development
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Production (add your Vercel URL)
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,https://hr-system.vercel.app,http://localhost:3000

# ==============================================
# Telegram Bot Configuration (Optional)
# ==============================================

# Get token from @BotFather on Telegram
# Leave empty to disable bot
HR_BOT_TOKEN=
HR_BOT_USERNAME=

# Production example:
# HR_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz-1234567
# HR_BOT_USERNAME=my_hr_bot

# ==============================================
# Spring Profile
# ==============================================

# Active profile: default (H2) or prod (PostgreSQL)
# SPRING_PROFILES_ACTIVE=prod

# ==============================================
# Server Configuration (Optional)
# ==============================================

# SERVER_PORT=8080

# ==============================================
# Notes:
# ==============================================
# 1. Copy this file to .env in the same directory
# 2. Update all values marked as IMPORTANT
# 3. Never commit .env file to Git
# 4. For production, use strong passwords and secrets
# 5. Restart backend after changing environment variables
