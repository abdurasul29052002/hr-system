# ==============================================
# HR System Frontend Environment Configuration
# ==============================================

# ==============================================
# Backend API URL
# ==============================================

# Local Development
NEXT_PUBLIC_BACKEND_URL=http://localhost:9090

# Production - Self-hosted backend
# NEXT_PUBLIC_BACKEND_URL=http://your-server-ip:9090

# Production - Custom domain with SSL
# NEXT_PUBLIC_BACKEND_URL=https://api.yourdomain.com

# ==============================================
# Public site origin (SEO) — REQUIRED in production
# ==============================================
# The public origin the site is served from, with NO trailing slash. Canonical links, Open Graph tags,
# JSON-LD, robots.txt and sitemap.xml are all built from this.
# MUST be set in Vercel (Production) and then REDEPLOYED: NEXT_PUBLIC_* is inlined at BUILD time, so
# changing it in the dashboard has no effect until the next build.
# If it does not match the host Google actually crawls, the sitemap is rejected as cross-host and link
# previews (Telegram, WhatsApp, Twitter) resolve to the wrong origin.

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Production example:
# NEXT_PUBLIC_SITE_URL=https://hrsystem.uz

# ==============================================
# Vercel Deployment
# ==============================================
# When deploying to Vercel:
# 1. Go to Vercel Dashboard → Your Project → Settings
# 2. Go to Environment Variables section
# 3. Add NEXT_PUBLIC_BACKEND_URL with your production backend URL
#    Example: https://api.yourdomain.com or http://your-server-ip:9090
# 4. Add NEXT_PUBLIC_SITE_URL with your public site origin (see above), then redeploy

# ==============================================
# Notes:
# ==============================================
# 1. Copy this file to .env.local for local development
# 2. NEXT_PUBLIC_* variables are exposed to the browser
# 3. Update NEXT_PUBLIC_BACKEND_URL to match your backend server
# 4. For Vercel deployment, configure in Vercel Dashboard (not in .env file)
# 5. Never commit .env.local to Git
# 6. Restart Next.js dev server after changing environment variables

